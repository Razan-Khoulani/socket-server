LARAVEL_APP_KEY=PUT_LARAVEL_APP_KEY_HERE
LARAVEL_BASE_URL=https://api.catch-syria.com

# On Plesk/Passenger, PORT is injected automatically.
# Keep SOCKET_BIND_PORT only as a local fallback.
SOCKET_BIND_PORT=4000
SOCKET_BIND_HOST=0.0.0.0

OSRM_BASE_URL=http://route.gocab.org

ENABLE_SOCKET_DB=0
DB_HOST=localhost
DB_USER=PUT_DB_USER
DB_PASSWORD=PUT_DB_PASSWORD
DB_NAME=PUT_DB_NAME

RIDE_TRACK_WRITE_DB=0
ENABLE_RIDE_TRACKING_SERVICE=1
RIDE_TRACK_FORCE_PASSED_EVENT=1
SIMPLE_PASSED_DEST_STATUSES=5
ALLOW_BUSY_DRIVER_NEAR_FINISH=1
BUSY_DRIVER_FINISH_RADIUS_M=500
MAX_QUEUED_RIDES_PER_DRIVER=1
QUEUE_ACTIVATE_TERMINAL_STATUSES=4,7,9,11
